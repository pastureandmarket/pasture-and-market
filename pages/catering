<!-- Catering Form -->
<section style="padding:2rem 3rem 6rem;background:var(--charcoal-lt);">
  <div class="catering-inner">
    <div class="catering-intro-grid">
      <div class="catering-image reveal-left">
        <!-- REPLACE: <img src="../images/catering.jpg" alt="Elegant catering setup"/> -->
        <div class="catering-image-frame" aria-hidden="true"></div>
      </div>

      <div class="reveal-right">
        <form id="catering-form" class="luxury-form" novalidate>
          <h3>Plan Your Event</h3>
          <p class="form-subtitle">Complete the form and our events team will contact you within 24 hours.</p>

          <!-- Contact -->
          <div class="form-group"><label for="cat-name">Full Name *</label><input type="text" id="cat-name" name="full-name" placeholder="Your full name" required/></div>
          <div class="form-row">
            <div class="form-group"><label for="cat-email">Email Address *</label><input type="email" id="cat-email" name="email" placeholder="your@email.com" required/></div>
            <div class="form-group"><label for="cat-phone">Phone Number *</label><input type="tel" id="cat-phone" name="phone" placeholder="(555) 000-0000" required/></div>
          </div>

          <!-- Event details -->
          <div class="form-row">
            <div class="form-group"><label for="cat-location">Location of Event</label><input type="text" id="cat-location" name="location" placeholder="Venue or address"/></div>
            <div class="form-group"><label for="cat-date">Date of Event</label><input type="date" id="cat-date" name="date"/></div>
          </div>
          <div class="form-row">
            <div class="form-group"><label for="cat-time">Event Start Time</label><input type="time" id="cat-time" name="start-time"/></div>
            <div class="form-group"><label for="cat-guests">Estimated Guest Count *</label><input type="number" id="cat-guests" name="guests" placeholder="e.g. 75" min="1"/></div>
          </div>

          <!-- Type of Event -->
          <div class="form-group">
            <p class="form-section-title">Type of Event</p>
            <div class="check-grid">
              <label class="check-item"><input type="checkbox" name="event-type" value="Golf Tournament"/><span>Golf Tournament</span></label>
              <label class="check-item"><input type="checkbox" name="event-type" value="Private Function"/><span>Private Function</span></label>
              <label class="check-item"><input type="checkbox" name="event-type" value="Corporate Dinner"/><span>Corporate Dinner</span></label>
              <label class="check-item"><input type="checkbox" name="event-type" value="Fundraiser"/><span>Fundraiser</span></label>
              <label class="check-item"><input type="checkbox" name="event-type" value="Wedding"/><span>Wedding</span></label>
              <label class="check-item"><input type="checkbox" name="event-type" value="Party"/><span>Party</span></label>
              <label class="check-item"><input type="checkbox" name="event-type" value="Other"/><span>Other</span></label>
            </div>
          </div>

          <!-- Dietary Restrictions -->
          <div class="form-group">
            <p class="form-section-title">Dietary Restrictions</p>
            <div class="check-grid">
              <label class="check-item"><input type="checkbox" name="dietary" value="None"/><span>None</span></label>
              <label class="check-item"><input type="checkbox" name="dietary" value="Vegetarian"/><span>Vegetarian</span></label>
              <label class="check-item"><input type="checkbox" name="dietary" value="Vegan"/><span>Vegan</span></label>
              <label class="check-item"><input type="checkbox" name="dietary" value="Kosher"/><span>Kosher</span></label>
              <label class="check-item"><input type="checkbox" name="dietary" value="Pork-free"/><span>Pork-free</span></label>
              <label class="check-item"><input type="checkbox" name="dietary" value="Gluten-free"/><span>Gluten-free</span></label>
              <label class="check-item"><input type="checkbox" name="dietary" value="Dairy-free"/><span>Dairy-free</span></label>
              <label class="check-item"><input type="checkbox" name="dietary" value="Other"/><span>Other</span></label>
            </div>
          </div>

          <!-- Type of Service (radio — single choice) -->
          <div class="form-group">
            <p class="form-section-title">Type of Service *</p>
            <div class="check-grid cols-3">
              <label class="check-item"><input type="radio" name="service" value="Pickup"/><span>Pickup</span></label>
              <label class="check-item"><input type="radio" name="service" value="Delivery"/><span>Delivery</span></label>
              <label class="check-item"><input type="radio" name="service" value="Buffet"/><span>Buffet</span></label>
              <label class="check-item"><input type="radio" name="service" value="Plated"/><span>Plated</span></label>
              <label class="check-item"><input type="radio" name="service" value="Other"/><span>Other</span></label>
            </div>
          </div>

          <!-- Budget & contact pref -->
          <div class="form-row">
            <div class="form-group"><label for="cat-budget">Budget per Person</label><input type="text" id="cat-budget" name="budget" placeholder="e.g. $50–$80 per person"/></div>
            <div class="form-group">
              <label for="cat-contact-pref">Preferred Contact Method</label>
              <select id="cat-contact-pref" name="contact-pref">
                <option value="">Select...</option>
                <option>Email</option><option>Phone Call</option><option>Text Message</option>
              </select>
            </div>
          </div>

          <div class="form-group"><label for="cat-describe">Describe Your Event *</label><textarea id="cat-describe" name="event-description" placeholder="Tell us about your vision, theme, and any special details..." required></textarea></div>
          <div class="form-group"><label for="cat-requests">Special Requests or Notes</label><textarea id="cat-requests" name="special-requests" placeholder="Any additional requests or questions..."></textarea></div>

          <!-- File upload -->
          <div class="form-group">
            <label for="cat-file">Attach Files (optional)</label>
            <!-- REPLACE: Wire to your actual upload endpoint -->
            <input type="file" id="cat-file" name="attachments" class="file-input-wrap" accept=".pdf,.doc,.docx,.jpg,.png"/>
          </div>

          <button type="submit" class="btn-submit">Send Catering Enquiry</button>
        </form>
      </div>
    </div>
  </div>
</section>

